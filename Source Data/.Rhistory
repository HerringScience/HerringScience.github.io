#Tag1 = Tag1 %>%
Tags = Tags %>%
dplyr::select(Tag_Num, Date, Lon, Lat, Vessel)
#changing Date from character class to Date class
Tags$Date <- ymd(Tags$Date)
Tags$Year <- as.numeric(format(Tags$Date, "%Y"))
CP6 <- ext(-68, -66, 44, 45)
GM <- crop(NBNS, CP6)
# CP6 <- as(extent(-68, -66, 44, 45), "SpatialPolygons")
