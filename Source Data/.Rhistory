#All Data at once
# All Data at once
ggplot() +
# 1. Draw your land mass instantly using terra's native ggplot extension
geom_spatvector(data = All, fill = "grey70", color = "grey50") +
# 2. Draw your box tracking polygons
geom_polygon(data = boxes, aes(x = X, y = Y, colour = Box), fill = NA, lwd = 1) +
# 3. Plot your point observations
geom_point(data = Tags, aes(x = Lon, y = Lat, colour = as.factor(Year)), size = 1) +
# 4. Use modern coordinate system bounds directly aligned with your data
coord_sf(xlim = c(-69, -62), ylim = c(42, 46)) +
labs(x = NULL, y = NULL, colour = "Year / Box") +
theme_minimal()
