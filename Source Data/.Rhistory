colour = "Year"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
avg_weights <- TotalFatData %>%
group_by(Year, LengthClass) %>%
summarise(
MeanWeight = mean(`FishWeight(g)`, na.rm = TRUE),
N = n(),
.groups = "drop"
)
