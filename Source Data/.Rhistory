leaflet(FatDataSum, options = leafletOptions(preferCanvas = TRUE)) %>%
addCircles(data = subset(FatDataSum, Lat > 40 & Lat < 47), color=~pal(Fat), popup = ~as.character(Fat)) %>%
addProviderTiles(providers$CartoDB.Positron, options = providerTileOptions(updateWhenZooming = FALSE, updateWhenIdle = TRUE)) %>%
clearBounds() %>%
addLegend("bottomright", pal = pal, values = ~Fat,
title = "Fat Percent (%)",
labFormat = labelFormat(suffix = "%"),
opacity = 1)
for(i in unique(FatData$Year)) {
cat("\n")
cat("######", i, "\n")
cat("\n")
FatData1 = FatData %>% filter(Month == 1)
print(FatData1 %>%
ggplot(aes(x=Lon, y=Lat)) +
geom_polygon(data=polysT,aes(x=X, y=Y, group=Box, fill = Box), colour = "black") +
geom_point(data=subset(FatData1, Lat < 46 & Lat > 40 & Year == i), aes(color=Fat)) +
scale_color_viridis_c(direction=-1) +
geom_polygon(data=out,aes(x=long, y=lat, group=group)) +
coord_map() +
theme(legend.position = 'bottom', legend.title = element_text(size = 10), legend.text = element_text(size=10)))
cat("\n")
}
for(i in unique(FatData$Year)) {
cat("\n")
cat("######", i, "\n")
cat("\n")
# Filter for the current month and year loop iteration
FatData1 <- FatData %>% filter(Month == 1 & Year == i)
p <- ggplot() +
# 1. Background Poly (polysT) - Moved fill outside aes() if you just want a solid/transparent background
geom_polygon(data = polysT, aes(x = X, y = Y, group = Box), fill = NA, colour = "black") +
# 2. Landmask layer (out) - Adjusted so it doesn't cover up your points
geom_polygon(data = out, aes(x = long, y = lat, group = group), fill = "grey80", colour = "black") +
# 3. Your Data Points (subset already handled above in FatData1)
geom_point(data = subset(FatData1, Lat < 46 & Lat > 40), aes(x = Lon, y = Lat, color = Fat), size = 2) +
scale_color_viridis_c(direction = -1) +
# 4. Map Projections and Theme
coord_map() +
theme(
legend.position = 'bottom',
legend.title = element_text(size = 10),
legend.text = element_text(size = 10)
)
print(p)
cat("\n")
}
for(i in unique(FatData$Year)) {
